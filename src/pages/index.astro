              <br />
              <span class="_dot"></span>
              <span class="p-top-mv-map__title cl-norewrite is-scrambling">Arts</span>
            </span>
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-performing.webp" data-sort="9" style="clip-path: inset(0px 0px 0px 100%);" />
          </li>
          <li class="_Architecture">
