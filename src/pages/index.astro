---
import Layout from "@layouts/Layout.astro";
const title = "KANEKA OLED EC";
const description = "";
const baseUrl = import.meta.env.VITE_BASE_URL || "/assets";
---

<Layout title={title}>
  <div class="fv">
    <ul class="fv__lead">
      <li class="fv__lead-text">
        <span>ゴ</span>
        <span>シ</span>
        <span>ョ</span>
        <span>ウ</span>
        <span>カ</span>
        <span>イ</span>
      </li>
      <li class="fv__lead-text">
        <span>サ</span>
        <span>ク</span>
        <span>ヒ</span>
        <span>ン</span>
        <span>ノ</span>
      </li>
    </ul>
    <div class="swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide fv__image">
          <picture>
            <source media="(min-width: 768px)" width="2100" height="696" srcset="/assets/images/mv_product.png" />
            <img src="/assets/images/mv_product.png" width="750" height="550" alt="" loading="lazy" />
          </picture>
        </div>
        <div class="swiper-slide fv__image">
          <picture>
            <source media="(min-width: 768px)" width="2100" height="696" srcset="/assets/images/mv_magazine.png" />
            <img src="/assets/images/mv_magazine.png" width="750" height="550" alt="" loading="lazy" />
          </picture>
        </div>
        <div class="swiper-slide fv__image">
          <picture>
            <source media="(min-width: 768px)" width="2100" height="696" srcset="/assets/images/mv_works.png" />
            <img src="/assets/images/mv_works.png" width="750" height="550" alt="" loading="lazy" />
          </picture>
        </div>
      </div>
      <div class="swiper-pagination-wrapper">
        <div class="swiper-pagination">
          <button data-slide="0">product </button>
          <button data-slide="1">magazine</button>
          <button data-slide="2">works</button>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="section__inner">
      <h2 class="section__title">product</h2>

      <div class="product">
        <div class="product__inner">
          <div class="product__content">
            <a class="product__link" href="#">
              <div class="product__item"><img src={`${baseUrl}/images/product_planning.png`} alt="" /></div>
              <div class="product__footer">
                <p class="product__footer-text">product</p>
                <div class="product__arrow">
                  <span class="product__arrow-arrow">(</span>
                  <span class="product__arrow-arrow">)</span>
                </div>
              </div>
            </a>
            <span class="product__text">Owned Media Planning</span>
          </div>

          <div class="product__content">
            <a class="product__link" href="#">
              <div class="product__item"><img src={`${baseUrl}/images/product_planning.png`} alt="" /></div>
              <div class="product__footer">
