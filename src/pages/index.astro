                </div>
              </div>
            </a>
            <span class="product__text">Owned Media Planning</span>
          </div>

          <div class="product__content">
            <a class="product__link" href="#">
              <p class="product__accent">To all those disillusioned with creativity. ベリーマン is the missing piece you need.</p>
              <div class="product__footer">
                <p class="product__footer-text">ビューオール</p>
                <div class="product__arrow">
                  <span class="product__arrow-arrow">(</span>
                  <span class="product__arrow-arrow">)</span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__inner">
      <div class="magazine">
        <div class="magazine__inner">
          <h2 class="magazine__title">magazine</h2>

          <div class="magazine__content">
            <div class="magazine__header">
              <h3 class="magazine__subtitle">マガジン</h3>
              <p class="magazine__read-text">The Magazine chronicles ベ リ ー マ ン and its partners' daily experiments and creative challenges.<br /> Updates are irregular, so please be patient as you wait for new content.</p>
            </div>
            <a href="#" class="magazine__content-inner">
              <div class="magazine__pic"><img src={`${baseUrl}/images/magazine.png`} alt="" /></div>
              <div class="magazine__footer">
                <p class="magazine__footer-text">ビューオール</p>
                <div class="magazine__arrow">
                  <span class="magazine__arrow-arrow">(</span>
                  <span class="magazine__arrow-arrow">)</span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__inner">
      <div class="section__header">
        <span class="section__accent">works</span>
        <h2 class="section__title">ワークス</h2>
      </div>

      <div class="works">
        <div class="works__inner">
          <ul class="works__box">
