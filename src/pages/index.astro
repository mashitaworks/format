                </li>
                <li class="works__box-items">
                  <span>Type</span>
                  <div class="works__box-type">
                    <span>Editorial</span>
                    <span>Copywriting</span>
                    <span>Movie</span>
                    <span>Website</span>
                    <span>Planning</span>
                    <span>Others</span>
