          <li class="_Art">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Art</span>
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-art.webp" data-sort="1" style="clip-path: inset(0px 0px 0px 100%);" />
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-art2.webp" data-sort="4" style="clip-path: inset(0px 0px 0px 100%);" />
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-art3.webp" data-sort="7" style="clip-path: inset(0px 0px 0px 100%);" />
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-art4.webp" data-sort="10" style="clip-path: inset(0px 0% 0px 0px);" />
          </li>
          <li class="_Sciences">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Sciences</span>
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-sciences.webp" data-sort="2" style="clip-path: inset(0px 0px 0px 100%);" />
          </li>
          <li class="_Music">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Music</span>
          </li>
          <li class="_Theater">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Theater</span>
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-theater.webp" data-sort="3" style="clip-path: inset(0px 0px 0px 100%);" />
          </li>
          <li class="_history">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">history</span>
          </li>
          <li class="_education">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Academic</span>
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-education.webp" data-sort="5" style="clip-path: inset(0px 0px 0px 100%);" />
          </li>
          <li class="_research">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Research</span>
          </li>
          <li class="_Literature">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Literature</span>
            <img class="p-top-mv-map__pic" src="https://nakanoshimalab.jp/wp/wp-content/themes/nakanoshimalab2025/assets/img/p-top-mv-map-literature.webp" data-sort="6" style="clip-path: inset(0px 0px 0px 100%);" />
          </li>
          <li class="_Ceramic">
            <span class="_dot"></span>
            <span class="p-top-mv-map__title cl-norewrite is-scrambling">Ceramic</span>
