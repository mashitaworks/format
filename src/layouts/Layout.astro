---
import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  keyword?: string;
  isForm?: boolean;
  isHome?: boolean;
  isSecond?: boolean;
  isThanks?: boolean;
}

// サイト共通のデフォルト値
const SITE_NAME = "AI × RETOUCH LAB";
const DEFAULT_TITLE = `AIとレタッチによる高品質ビジュアル制作サービス「${SITE_NAME}」`;
const DEFAULT_DESCRIPTION = "AIの創造性とレタッチャーの審美眼で、静止画から動画まで広告品質に仕上げます。撮影や既存素材では難しい理想を形にするビジュアル制作サービス。";
const DEFAULT_OG_IMAGE = "ai-ret/ogp.webp";
const DEFAULT_KEYWORDS = "AI × レタッチ, 人の審美眼,  AI 高品質,  画像生成,  広告品質,  ビジュアル , フォトリアル , 画像生成 クリエイティブ補正,  高精度レタッチ";

const SITE_URL = "https://www.gen-zo.com/ai-ret";

const { title = DEFAULT_TITLE, description = DEFAULT_DESCRIPTION, ogImage = DEFAULT_OG_IMAGE, keyword = DEFAULT_KEYWORDS, isForm = false, isHome = false, isSecond = false, isThanks = false } = Astro.props;

// ページタイトル（トップ以外はサイト名を付与）
const pageTitle = isHome ? title : `${title} | ${SITE_NAME}`;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
const isDev = import.meta.env.MODE === "development";
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- format -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keyword} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`/favicon.ico`} type="image/png" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={isHome ? "website" : "article"} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Roboto:ital,wght@0,100..900;1,100..900&family=Zen+Kaku+Gothic+New&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />

    {
      isDev ? (
        <link rel="stylesheet" href="/src/styles/style.scss" /> // 開発時
      ) : (
        <link rel="stylesheet" href="/assets/css/style.css" /> // ビルド時
      )
    }
  </head>
  <body>
    <div id="wrapper">
      <Header />
      <main id="main">
        <slot />
      </main>
    </div>
    <script is:inline src="/assets/js/swiper-bundle.min.js"></script>

    {
      isDev ? (
        <script src="/src/scripts/main.js" /> // 開発時
      ) : (
        <script src="/assets/js/main.js" /> // ビルド時
      )
    }
  </body>
</html>
